{
  "name": "red-salud",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.4.0",
  "scripts": {
    "nx": "nx",
    "dev": "echo 'Use dev:<app>:web or dev:<app>:desktop (e.g., pnpm dev:medico:web)'",
    "build": "pnpm build:packages && pnpm -r --filter './apps/*/web' build",
    "build:packages": "pnpm -r --filter './packages/*' build",
    "start": "echo 'Use start in specific app (e.g., pnpm --filter @red-salud/medico-web start)'",
    "dev:farmacia:web": "pnpm --filter @red-salud/farmacia-web dev",
    "dev:medico:web": "pnpm --filter @red-salud/medico-web dev",
    "dev:paciente:web": "pnpm --filter @red-salud/paciente-web dev",
    "dev:clinica:web": "pnpm --filter @red-salud/clinica-web dev",
    "dev:laboratorio:web": "pnpm --filter @red-salud/laboratorio-web dev",
    "dev:secretaria:web": "pnpm --filter @red-salud/secretaria-web dev",
    "dev:seguro:web": "pnpm --filter @red-salud/seguro-web dev",
    "dev:ambulancia:web": "pnpm --filter @red-salud/ambulancia-web dev",
    "dev:academia:web": "pnpm --filter @red-salud/academia-web dev",
    "dev:farmacia:desktop": "pnpm --filter @red-salud/farmacia-desktop tauri dev",
    "dev:medico:desktop": "pnpm --filter @red-salud/medico-desktop tauri dev",
    "tauri:farmacia:dev": "pnpm --filter @red-salud/farmacia-desktop tauri:dev",
    "tauri:medico:dev": "pnpm --filter @red-salud/medico-desktop tauri:dev",
    "lint": "pnpm -r lint",
    "lint:all": "nx run-many -t lint --all --outputStyle=static",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "services:dev": "cd services && cargo watch -x run",
    "services:build": "cd services && cargo build --release",
    "clean": "pnpm -r exec rm -rf node_modules dist .next build coverage"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@nx/eslint-plugin": "^22.5.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^16.4.0",
    "knip": "^5.83.1",
    "next": "16.1.0",
    "nx": "22.5.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "syncpack": "^13.0.4",
    "typescript-eslint": "^8.46.1"
  }
}
