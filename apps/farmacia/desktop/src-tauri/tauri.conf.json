{
  "$schema": "https://raw.githubusercontent.com/nickelpack/tauri/refs/heads/dev/crates/tauri-cli/schema.json",
  "productName": "Red Salud Farmacia",
  "version": "0.1.0",
  "identifier": "com.redsalud.farmacia",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "title": "Red Salud - Farmacia",
    "windows": [
      {
        "title": "Red Salud - Farmacia",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
